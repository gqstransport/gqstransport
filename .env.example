# gqs-backend (PORT=4000). Ensure gqs-backend CORS_ORIGINS includes http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000

# SMTP — contact, quote & newsletter (Next.js /api/contact, /api/quote, /api/newsletter)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="GQS Website <your-email@gmail.com>"
MAIL_TO=info@gqstransport.com
